# ─────────────────────────────────────────────────────────────────────────────
# TaxAI Backend — Environment Variables
# Fill in whatever credentials you receive at the codeathon.
# Leave a value blank and the system auto-falls back to the next option.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI (GPT-4.5) ───────────────────────────────────────────────────
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4.5
AZURE_OPENAI_API_VERSION=2024-02-01

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net
# Local: mongodb://localhost:27017
MONGODB_URI=
MONGODB_DB=taxai

# ─────────────────────────────────────────────────────────────────────────────
# Leave both sections empty → runs with rule-based NLP + in-memory storage
# ─────────────────────────────────────────────────────────────────────────────
